---
{% if title %}title: "{{ title|replace('"', '\\"') }}"
{% endif %}
{% if source %}source: {{ source }}
{% endif %}
{% if uploader %}uploader: "{{ uploader|replace('"', '\\"') }}"
{% endif %}
{% if upload_date %}upload_date: {{ upload_date }}
{% endif %}
{% if duration_sec is not none %}duration_sec: {{ "%.1f"|format(duration_sec) }}
{% endif %}
{% if language %}language: {{ language }}
{% endif %}
model: {{ model }}
created: {{ created }}
---

{% if title %}# {{ title }}

{% endif %}
{% for seg in segments %}
{{ seg.text }}
{% endfor %}
